# Copy this file to `.env` in the repo root and fill in DATABASE_URL.
# Every other value shown is the default used when unset.

# ── App ──────────────────────────────────────────────
APP_NAME="PartyPe API"
APP_VERSION=3.0
ENVIRONMENT=development
DEBUG=true

# ── API versioning ───────────────────────────────────
API_V1_PREFIX=/api/v1
LEGACY_API_PREFIX=/api

# ── Database (PostgreSQL / Neon) ─────────────────────
# No default — required. Get a free Postgres instance at
# https://neon.tech, then from the Neon dashboard copy the *pooled*
# connection string (the one on port 6543, using their PgBouncer
# endpoint — not the direct :5432 endpoint) for normal app traffic.
# It looks like:
#   postgresql+psycopg://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
# Local dev against a plain local Postgres instead:
#   postgresql+psycopg://postgres:postgres@localhost:5432/partype
DATABASE_URL=
DATABASE_ECHO=false
# See app/core/config.py for what each of these does and why these
# particular defaults suit Neon's free tier.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE_SECONDS=300
DB_POOL_PRE_PING=true

# ── CORS ─────────────────────────────────────────────
# Comma-separated list, e.g. http://localhost:3000,https://partype.com
CORS_ALLOW_ORIGINS=*

# ── Auth ─────────────────────────────────────────────
TOKEN_TTL_DAYS=30

# Copy this file to `.env` in the repo root and adjust as needed.
# All values shown are the defaults used when a variable is unset.

# ── App ──────────────────────────────────────────────
APP_NAME="PartyPe API"
APP_VERSION=2.0
ENVIRONMENT=development
DEBUG=true

# ── API versioning ───────────────────────────────────
API_V1_PREFIX=/api/v1
LEGACY_API_PREFIX=/api

# ── Database ─────────────────────────────────────────
DATABASE_URL=sqlite:///./partype.db
DATABASE_ECHO=false

# ── CORS ─────────────────────────────────────────────
# Comma-separated list, e.g. http://localhost:3000,https://partype.com
CORS_ALLOW_ORIGINS=*

# ── Auth ─────────────────────────────────────────────
TOKEN_TTL_DAYS=30
